{
  "name": "orchestra-api",
  "version": "0.1.0",
  "description": "Open-source multi-agent orchestration API. Define agent graphs, run them, stream events. MCP-friendly Bearer auth.",
  "type": "module",
  "license": "MIT",
  "author": "codewithzhiva",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codewithzhiva/orchestra-api.git"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "tsx src/workers/runner.ts",
    "worker:prod": "node dist/workers/runner.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.1",
    "@langchain/core": "^0.3.18",
    "@langchain/langgraph": "^0.2.19",
    "@langchain/ollama": "^0.1.2",
    "argon2": "^0.41.1",
    "better-sqlite3": "^11.5.0",
    "bullmq": "^5.28.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "nanoid": "^5.0.8",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
